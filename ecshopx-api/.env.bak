# 应用名称
APP_NAME=EcshopX2.0
# 标识应用环境, 本地环境设置为local,生产环境为production
APP_ENV=production
# 数据加密密钥
APP_KEY==base64:wtoE4f8XENko609Kntigp+FZSMHGu7+oss7Apg1IZ7s=
# 调试模式, 正式环境需要关闭(true,false)
